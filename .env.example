# MiniMax API配置
MINIMAX_API_KEY=your_minimax_api_key_here
MINIMAX_API_URL=https://api.minimax.chat/v1

# Ollama配置（可选，用于本地LLM）
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# ChromaDB配置
CHROMA_DB_PATH=./knowledge-base/chroma

# 知识库路径
KNOWLEDGE_BASE_PATH=./docs

# Agent服务配置
AGENT_PORT=8001
AGENT_HOST=0.0.0.0

# Demo后端配置
DEMO_PORT=8000
DEMO_HOST=0.0.0.0
